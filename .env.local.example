# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# ----- Supabase (https://supabase.com → Project Settings → API) -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Clerk (https://clerk.com → API Keys) -----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Clerk → Webhooks → Add endpoint, then paste the signing secret here.
# Subscribe the endpoint to `user.created` and `user.deleted`. Endpoint URL:
#   https://YOUR-DOMAIN/api/webhooks/clerk    (use ngrok / Clerk's "Sync host" for local dev)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# Tell Clerk where to send users after sign-in / sign-up. These can stay as-is.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app/onboarding
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app/onboarding

# ----- Anthropic (powers the Stage 5 auto-suggest engine) -----
# Get an API key at https://console.anthropic.com -> Settings -> API Keys.
# Set a spend cap at Settings -> Limits BEFORE adding the key.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ----- Rate limits on Claude-touching endpoints (optional overrides) -----
# Per-project sliding-window limits. Defaults are sized so 5 concurrent
# customers can't exhaust a $10 Anthropic spend cap in a day at Sonnet
# 4.6 prices. Tune up once you're confident in real-world usage.
# SAFESHIP_SUGGEST_DAILY_LIMIT=50
# SAFESHIP_SUGGEST_BURST_LIMIT=5
# SAFESHIP_SUGGEST_BURST_WINDOW_SECONDS=300

# ----- Rate limits on /v1/traces ingestion (optional overrides) -----
# Caps how many runs a single project can ingest per window. Higher than
# the Claude limits because ingestion is just DB writes — but tight
# enough that a leaked API key can't bloat the DB by millions of rows.
# SAFESHIP_TRACES_DAILY_LIMIT=5000
# SAFESHIP_TRACES_BURST_LIMIT=100
# SAFESHIP_TRACES_BURST_WINDOW_SECONDS=60

# ----- Auto-suggest model (cost vs quality tradeoff) -----
# Defaults to claude-sonnet-4-6. Swap to:
#   claude-haiku-4-5  -> ~3x cheaper, slight quality drop
#   claude-opus-4-7   -> ~2x more expensive, smartest model
# Then set in Vercel env vars too if you want it to apply in prod.
# SAFESHIP_SUGGEST_MODEL=claude-sonnet-4-6
# SAFESHIP_SUGGEST_MAX_TOKENS=2048

# ----- Stripe (billing — 7-day card-upfront trial → $29/mo auto-renew) -----
# Get keys at https://dashboard.stripe.com -> Developers -> API keys.
# Use TEST keys for local dev (sk_test_*) and LIVE keys in Vercel for prod.
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# Create a Product in Stripe -> Product catalog. Add a recurring price:
#   $29 / month, no free trial on the price (trial is set per-checkout).
# Copy the price ID (starts with price_) here.
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# Stripe -> Developers -> Webhooks -> Add endpoint. Endpoint URL:
#   https://YOUR-DOMAIN/api/webhooks/stripe    (use Stripe CLI `stripe listen` for local dev)
# Subscribe to:
#   checkout.session.completed
#   customer.subscription.created
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.payment_succeeded
#   invoice.payment_failed
# Then copy the signing secret (whsec_*) here.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Owner accounts (grandfathered — bypass Stripe gating entirely) -----
# Comma-separated list of Clerk user ids. Anyone in this list gets full
# /app/* access without a Stripe subscription. Use this for your own
# account so you don't have to pay yourself $29/mo to dogfood.
# Find your Clerk user id at https://dashboard.clerk.com -> Users -> click yourself.
# SAFESHIP_OWNER_CLERK_IDS=user_xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Resend (transactional email — leave blank for now) -----
# RESEND_API_KEY=
